<article class="post-card{{ class ? ' ' ~ class : '' }}">
  <a class="post-card__media" href="{{ post.permalink }}">
    {% if post.image %}
      <img
        src="{{ post.image }}"
        alt="{{ post.imageAlt ?: post.title }}"
        loading="lazy"
      >
    {% else %}
      <span class="post-card__placeholder">{{ placeholder|default('No image') }}</span>
    {% endif %}
  </a>

  <div class="post-card__body">
    <div class="post-card__meta">
      {% if post.date %}
        <span>{{ post.date }}</span>
      {% endif %}
      {% if post.author %}
        <span>{{ post.author }}</span>
      {% endif %}
    </div>

    <h3 class="post-card__title">
      <a href="{{ post.permalink }}">{{ post.title }}</a>
    </h3>

    {% if post.excerpt %}
      <div class="post-card__excerpt">
        {{ post.excerpt }}
      </div>
    {% endif %}

    <a class="post-card__link" href="{{ post.permalink }}">
      {{ read_more_label|default('Read more') }}
    </a>
  </div>
</article>
