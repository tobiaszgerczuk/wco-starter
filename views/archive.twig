{% extends "base.twig" %}

{% block content %}
  <section class="archive-hero">
    <div class="container">
      <span class="archive-hero__eyebrow">{{ __('Archive', 'wco-starter') }}</span>
      <h1 class="archive-hero__title">{{ archive_title }}</h1>

      {% if archive_description %}
        <div class="archive-hero__description">{{ archive_description|raw }}</div>
      {% endif %}
    </div>
  </section>

  <section class="archive-listing">
    <div class="container">
      {% if posts %}
        <div class="post-grid">
          {% for post in posts %}
            <article class="post-card">
              <a class="post-card__media" href="{{ post.link }}">
                {% if post.thumbnail %}
                  <img src="{{ post.thumbnail.src('large') }}" alt="{{ post.thumbnail.alt ?: post.title }}">
                {% else %}
                  <span class="post-card__placeholder">{{ __('No image', 'wco-starter') }}</span>
                {% endif %}
              </a>

              <div class="post-card__body">
                <div class="post-card__meta">
                  <time datetime="{{ post.date('c') }}">{{ post.date('d.m.Y') }}</time>
                  {% if post.terms('category') %}
                    <span>{{ post.terms('category')|first.name }}</span>
                  {% endif %}
                </div>

                <h2 class="post-card__title">
                  <a href="{{ post.link }}">{{ post.title }}</a>
                </h2>

                <p class="post-card__excerpt">{{ post.preview.length(28) }}</p>

                <a class="post-card__link" href="{{ post.link }}">{{ __('Read more', 'wco-starter') }}</a>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if posts.pagination.pages %}
          <nav class="pagination" aria-label="{{ __('Posts navigation', 'wco-starter') }}">
            {% if posts.pagination.prev %}
              <a class="pagination__link pagination__link--prev" href="{{ posts.pagination.prev.link }}">{{ __('Previous', 'wco-starter') }}</a>
            {% endif %}

            {% for page in posts.pagination.pages %}
              {% if page.link %}
                <a class="pagination__link {{ page.current ? 'is-current' : '' }}" href="{{ page.link }}">{{ page.title }}</a>
              {% else %}
                <span class="pagination__link pagination__link--dots">{{ page.title }}</span>
              {% endif %}
            {% endfor %}

            {% if posts.pagination.next %}
              <a class="pagination__link pagination__link--next" href="{{ posts.pagination.next.link }}">{{ __('Next', 'wco-starter') }}</a>
            {% endif %}
          </nav>
        {% endif %}
      {% else %}
        <div class="empty-state">
          <h2>{{ __('No posts found.', 'wco-starter') }}</h2>
          <p>{{ __('There is nothing to display here yet.', 'wco-starter') }}</p>
        </div>
      {% endif %}
    </div>
  </section>
{% endblock %}
