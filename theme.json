{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1360px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "text",
          "name": "Text",
          "color": "#191919"
        },
        {
          "slug": "bg",
          "name": "Background",
          "color": "#ffffff"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#f7f3eb"
        },
        {
          "slug": "surface-strong",
          "name": "Surface Strong",
          "color": "#efe7d8"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "#d9cfbf"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#666666"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#5ab25e"
        },
        {
          "slug": "primary-hover",
          "name": "Primary Hover",
          "color": "#449048"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#7a5937"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#cdae7f"
        },
        {
          "slug": "black",
          "name": "Black",
          "color": "#111111"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "%",
        "vw"
      ],
      "spacingSizes": [
        {
          "slug": "none",
          "name": "None",
          "size": "0"
        },
        {
          "slug": "xs",
          "name": "XS",
          "size": "1.5rem"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "2.5rem"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "4rem"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "6rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "8rem"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "lineHeight": true,
      "fontFamilies": [
        {
          "slug": "base",
          "name": "Base",
          "fontFamily": "'Montserrat', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "'Montserrat', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "fontFamily": "'Lavishly Yours', cursive"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "2rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "text": "var(--wp--preset--color--text)",
      "background": "var(--wp--preset--color--bg)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "radius": "10px"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem"
    }
  }
}
